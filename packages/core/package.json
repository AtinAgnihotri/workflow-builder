{
  "name": "@journeys/core",
  "version": "0.1.0",
  "description": "Framework-agnostic workflow definition, validation, and evaluation primitives.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "./dist/index.js",
