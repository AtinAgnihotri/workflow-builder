    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  }
}
